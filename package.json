{
  "name": "ephemeral-pages",
  "version": "0.5.0",
  "private": true,
  "description": "Publish short-lived HTML pages that expire automatically.",
  "keywords": [
    "ephemeral",
    "html",
    "lit",
    "netlify",
    "publishing",
    "temporary-pages",
    "vite"
  ],
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "vp dev",
    "build": "tsc && vp build",
    "css:sort": "stylelint \"src/**/*.css\" --fix",
    "preview": "vp preview",
    "test": "vp test",
    "test:e2e": "playwright test",
    "prepare": "vp config"
  },
  "dependencies": {
    "@netlify/blobs": "^10.7.6",
    "@netlify/functions": "^5.2.1",
    "@sentry/node": "^10.53.1",
    "lit": "^3.3.2",
    "lucide": "^1.14.0",
    "parse5": "^8.0.1",
    "urlpattern-polyfill": "^10.1.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.57.0",
    "@varlock/1password-plugin": "^1.1.0",
    "stylelint": "^17.11.1",
    "stylelint-order": "^8.1.1",
    "typescript": "~6.0.2",
    "varlock": "^1.2.0",
    "vite": "npm:@voidzero-dev/vite-plus-core@latest",
    "vite-plus": "latest"
  },
  "overrides": {
    "vite": "npm:@voidzero-dev/vite-plus-core@latest",
    "vitest": "npm:@voidzero-dev/vite-plus-test@latest"
  },
  "packageManager": "bun@1.3.14"
}
